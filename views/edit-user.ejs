<%- include("partials/header") %>

    <div class="container-fluid page-body-wrapper">

        <div class="main-panel">
            <div class="content-wrapper">
                <%- include("partials/sidebar") %>
                <div class="row justify-content-center">
                    <div class="col-lg-10 zero-px">

                        <div class="card zero-px">

                            <div class="card-header d-flex justify-content-between align-items-center ">

                                <h3 class="fs-3 mb-3 mt-3">Edit User</h3>

                               

                            </div>

                            <div class="card-body">

                                <%- include("partials/flash") %>

                                    <form action="/update-user/<%= user._id %>" method="POST" enctype="multipart/form-data">
                                    
                                    <div class="row">
                                    
                                        <div class="col-md-6">
                                            <div class="form-group mb-3">
                                                <label>First Name</label>
                                                <input type="text" name="firstName" class="form-control"
                                                    value="<%= formData?.firstName ?? user.firstName %>" required>
                                            </div>
                                        </div>
                                    
                                        <div class="col-md-6">
                                            <div class="form-group mb-3">
                                                <label>Last Name</label>
                                                <input type="text" name="lastName" class="form-control" value="<%= formData?.lastName ?? user.lastName %>"
                                                    required>
                                            </div>
                                        </div>
                                    
                                        <div class="col-md-6">
                                            <div class="form-group mb-3">
                                                <label>Username</label>
                                                <input type="text" name="username" class="form-control" value="<%= formData?.username ?? user.username %>"
                                                    required>
                                            </div>
                                        </div>
                                    
                                        <div class="col-md-6">
                                            <div class="form-group mb-3">
                                                <label>Email</label>
                                                <input type="email" name="email" class="form-control" value="<%= formData?.email ?? user.email %>" required>
                                            </div>
                                        </div>
                                    
                                        <div class="col-md-6">
                                            <div class="form-group mb-3">
                                                <label>Mobile Number</label>
                                                <input type="text" name="mobile" class="form-control" value="<%= formData?.mobile ?? user.mobile %>">
                                            </div>
                                        </div>
                                    
                                        <div class="col-md-6">
                                            <div class="form-group mb-3">
                                                <label>City</label>
                                                <input type="text" name="city" class="form-control" value="<%= formData?.city ?? user.city %>">
                                            </div>
                                        </div>
                                    
                                        <div class="col-md-6">
                                            <div class="form-group mb-3">
                                                <label>Date of Birth</label>
                                                <input type="date" name="dob" class="form-control"
                                                    value="<%= formData?.dob ?? (user.dob ? new Date(user.dob).toISOString().split('T')[0] : '') %>">
                                            </div>
                                        </div>
                                    
                                        <div class="col-md-6">
                                            <div class="form-group mb-3">
                                                <label>Hobby</label>
                                                <input type="text" name="hobby" class="form-control" value="<%= formData?.hobby ?? user.hobby %>">
                                            </div>
                                        </div>
                                    
                                        <div class="col-md-6">
                                            <div class="form-group mb-3">
                                    
                                                <label>Gender</label>
                                    
                                                <select name="gender" class="form-control">
                                    
                                                    <option value="">Select Gender</option>
                                    
                                                    <option value="Male" <%=(formData?.gender ?? user.gender)==="Male" ? "selected" : "" %>>
                                                        Male
                                                    </option>
                                    
                                                    <option value="Female" <%=(formData?.gender ?? user.gender)==="Female" ? "selected" : "" %>>
                                                        Female
                                                    </option>
                                    
                                                    <option value="Other" <%=(formData?.gender ?? user.gender)==="Other" ? "selected" : "" %>>
                                                        Other
                                                    </option>
                                    
                                                </select>
                                    
                                            </div>
                                        </div>
                                    
                                        <div class="col-md-6">
                                            <div class="form-group mb-3">
                                    
                                                <label>Role</label>
                                    
                                                <select name="role" class="form-control">
                                    
                                                    <option value="Admin" <%=(formData?.role ?? user.role)==="Admin" ? "selected" : "" %>>
                                                        Admin
                                                    </option>
                                    
                                                    <option value="Manager" <%=(formData?.role ?? user.role)==="Manager" ? "selected" : "" %>>
                                                        Manager
                                                    </option>
                                    
                                                    <option value="Employee" <%=(formData?.role ?? user.role)==="Employee" ? "selected" : "" %>>
                                                        Employee
                                                    </option>
                                    
                                                    
                                    
                                                </select>
                                    
                                            </div>
                                        </div>
                                    
                                        <div class="col-12 mb-4">
                                    
                                            <label class="mb-3">Profile Image</label>
                                    
                                            <div class="row align-items-center">
                                    
                                                <div class="col-md-2 text-center">
                                    
                                                    <img src="/uploads/<%= user.avatar %>" class="img-thumbnail"
                                                        style="width:140px;height:140px;object-fit:cover;border-radius:12px;">
                                    
                                                    <small class="d-block mt-2 text-muted">
                                                        Current Image
                                                    </small>
                                    
                                                </div>
                                    
                                                <div class="col-md-10">
                                    
                                                    <label class="text-muted mb-2">
                                                        Upload New Image
                                                    </label>
                                    
                                                    <input type="file" name="avatar" class="form-control">
                                    
                                                    <small class="text-muted mt-2 d-block">
                                                        Leave this empty if you don't want to change the profile image.
                                                    </small>
                                    
                                                </div>
                                    
                                            </div>
                                    
                                        </div>
                                    
                                        <div class="col-12">
                                            <div class="form-group mb-3">
                                    
                                                <label>Address</label>
                                    
                                                <textarea name="address" rows="3" class="form-control"><%= formData?.address ?? user.address %></textarea>
                                    
                                            </div>
                                        </div>
                                    
                                        <div class="col-12">
                                            <div class="form-group mb-4">
                                    
                                                <label>Bio</label>
                                    
                                                <textarea name="bio" rows="5" maxlength="300"
                                                    class="form-control"><%= formData?.bio ?? user.bio %></textarea>
                                    
                                                <small class="text-muted">
                                                    Maximum 300 characters
                                                </small>
                                    
                                            </div>
                                        </div>
                                    
                                    </div>
                                        <hr>
                                    
                                        <div class="d-flex justify-content-end">
                                    
                                            <a href="/views" class="btn btn-light me-2">
                                                Cancel
                                            </a>
                                    
                                            <button type="submit" class="btn btn-primary">
                                                <i class="ti-save me-1"></i>
                                                Update User
                                            </button>
                                    
                                        </div>
                                    
                                    </form>

                            </div>

                        </div>

                    </div>
                </div>

            </div>

        </div>

        <%- include("partials/footer") %>